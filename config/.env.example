# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=myorg
INFLUXDB_BUCKET=app_energy
INFLUXDB_TOKEN=your-influxdb-token-here

# Collection Configuration
COLLECTION_INTERVAL=60
CSV_PATH=data/energy_log.csv
LOG_PATH=logs/daemon.log

# App Filtering (comma-separated)
# If APP_WHITELIST is set, only these apps are monitored
APP_WHITELIST=

# Apps to exclude from monitoring
APP_BLACKLIST=kernel_task,system,loginwindow,Finder
